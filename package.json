{
  "name": "label-os",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=10.13.1"
  },
  "scripts": {
    "dev": "turbo dev",
    "api:dev": "cd apps/api && python scripts/dev.py",
    "api:test": "cd apps/api && python -m pytest",
    "api:test:coverage": "cd apps/api && python -m pytest --cov=labelos_api --cov-report=term-missing --cov-report=xml",
    "api:lint": "cd apps/api && python -m ruff check .",
    "api:format": "cd apps/api && python -m black .",
    "agents:dev": "cd apps/agents && uvicorn labelos_agents.main:app --reload --host 0.0.0.0 --port 4100",
    "agents:health": "cd apps/agents && python scripts/health.py health",
    "agents:test": "cd apps/agents && python -m pytest",
    "agents:test:coverage": "cd apps/agents && python -m pytest --cov=labelos_agents --cov-report=term-missing --cov-report=xml",
    "agents:lint": "cd apps/agents && python -m ruff check .",
    "agents:format": "cd apps/agents && python -m black .",
    "compose": "node scripts/docker-compose.mjs",
    "db:start": "node scripts/docker-compose.mjs up -d postgres",
    "db:migrate": "cd apps/api && python -m alembic -c ../../packages/database/alembic.ini upgrade head",
    "db:migration": "cd apps/api && python -m alembic -c ../../packages/database/alembic.ini revision --autogenerate",
    "db:rollback": "cd apps/api && python -m alembic -c ../../packages/database/alembic.ini downgrade -1",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "turbo typecheck",
    "test": "turbo test && cd apps/api && python -m pytest && cd ../agents && python -m pytest",
    "test:web": "turbo test --filter=@label-os/web --filter=@label-os/ui",
    "test:api": "cd apps/api && python -m pytest",
    "test:coverage": "turbo test:coverage && cd apps/api && python -m pytest --cov=labelos_api --cov-report=term-missing --cov-report=xml && cd ../agents && python -m pytest --cov=labelos_agents --cov-report=term-missing --cov-report=xml",
    "clean": "turbo clean"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.31.0",
    "jsdom": "^29.1.1",
    "pnpm": "10.13.1",
    "prettier": "^3.6.2",
    "turbo": "^2.5.5",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.37.0",
    "vitest": "^4.1.10"
  }
}
