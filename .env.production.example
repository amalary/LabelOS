# Label OS production environment template
# Do not place real production values in committed files.

NODE_ENV=production
APP_ENV=production

# Frontend production
WEB_BASE_URL=https://<your-web-domain>
WEB_PORT=3000
NEXT_PUBLIC_API_URL=https://<your-api-domain>
NEXT_PUBLIC_WORKOS_REDIRECT_URI=https://<your-web-domain>/api/auth/callback

# Backend production
API_HOST=0.0.0.0
API_PORT=4000
API_BASE_URL=https://<your-api-domain>
ALLOWED_FRONTEND_ORIGINS=https://<your-web-domain>
DATABASE_URL=postgresql+asyncpg://<user>:<password>@<host>:5432/<database>
DATABASE_ECHO=false

# WorkOS production
AUTH_PROVIDER=workos
WORKOS_CLIENT_ID=client_replace_with_workos_client_id
WORKOS_API_KEY=sk_replace_with_workos_api_key
WORKOS_COOKIE_PASSWORD=replace-with-generated-cookie-password
WORKOS_REDIRECT_URI=https://<your-web-domain>/api/auth/callback
WORKOS_ISSUER_URL=https://api.workos.com
WORKOS_JWKS_URL=
WORKOS_WEBHOOK_SECRET=whsec_replace_when_webhooks_are_enabled

# Agent service production
AGENTS_HOST=0.0.0.0
AGENTS_PORT=4100
AGENTS_LOG_LEVEL=INFO
AGENTS_MODEL_PROVIDER=<provider>
AGENTS_MODEL_NAME=<model>
AGENTS_MODEL_TIMEOUT_SECONDS=30
AGENTS_REQUIRE_HUMAN_APPROVAL=true
AGENTS_OPENAI_API_KEY=<set-in-secret-manager-if-used>
AGENTS_ANTHROPIC_API_KEY=<set-in-secret-manager-if-used>
AGENTS_GOOGLE_API_KEY=<set-in-secret-manager-if-used>

LOG_LEVEL=INFO
